API_SECRET_KEY=your-api-secret-key-here

# planhigh (planhigh.co.kr) — Supabase 탈출 후 ERP 앱이 /api/planhigh/* 로 직접 서빙
PLANHIGH_ADMIN_SECRET=                      # planhigh 어드민 토큰 서명 시크릿(>=16자 랜덤)
PLANHIGH_ALLOWED_ORIGINS=https://planhigh.co.kr,https://www.planhigh.co.kr

# Amazon SES SMTP (메일 발송)
SES_SMTP_HOST=email-smtp.ap-northeast-2.amazonaws.com
SES_SMTP_PORT=587
SES_SMTP_USER=
SES_SMTP_PASS=
MAIL_FROM_ADDRESS=noreply@vi-mo.kr
MAIL_FROM_NAME=비모

# Amazon SES Inbound (받은 메일 -> S3)
INBOUND_S3_BUCKET=
INBOUND_S3_REGION=ap-northeast-2
INBOUND_S3_PREFIX=inbound/
INBOUND_AWS_ACCESS_KEY_ID=
INBOUND_AWS_SECRET_ACCESS_KEY=
